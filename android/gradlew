#!/usr/bin/env sh

# Lightweight Gradle bootstrap for Asgard TV.
# Uses the Gradle version declared in gradle/wrapper/gradle-wrapper.properties.
# This keeps GitHub Actions and local builds independent from globally installed Gradle.

set -e

APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROPERTIES_FILE="$APP_HOME/gradle/wrapper/gradle-wrapper.properties"

if [ ! -f "$PROPERTIES_FILE" ]; then
  echo "Missing Gradle wrapper properties: $PROPERTIES_FILE" >&2
  exit 1
fi

DISTRIBUTION_URL=$(sed -n 's/^distributionUrl=//p' "$PROPERTIES_FILE" | sed 's/\\:/:/g')
if [ -z "$DISTRIBUTION_URL" ]; then
  echo "distributionUrl is missing in $PROPERTIES_FILE" >&2
  exit 1
fi

ZIP_NAME=$(basename "$DISTRIBUTION_URL")
DIST_NAME=$(basename "$DISTRIBUTION_URL" .zip)
GRADLE_HOME_NAME=$(printf '%s' "$DIST_NAME" | sed 's/-bin$//' | sed 's/-all$//')
GRADLE_USER_HOME_DIR="${GRADLE_USER_HOME:-$HOME/.gradle}"
DIST_DIR="$GRADLE_USER_HOME_DIR/wrapper/dists/$DIST_NAME"
GRADLE_BIN="$DIST_DIR/$GRADLE_HOME_NAME/bin/gradle"
ZIP_FILE="$DIST_DIR/$ZIP_NAME"

if [ ! -x "$GRADLE_BIN" ]; then
  mkdir -p "$DIST_DIR"
  echo "Downloading $DIST_NAME from $DISTRIBUTION_URL"
  if command -v curl >/dev/null 2>&1; then
    curl -fL --retry 3 --connect-timeout 30 -o "$ZIP_FILE" "$DISTRIBUTION_URL"
  elif command -v wget >/dev/null 2>&1; then
    wget -O "$ZIP_FILE" "$DISTRIBUTION_URL"
  else
    echo "Neither curl nor wget is available to download Gradle." >&2
    exit 1
  fi
  unzip -q -o "$ZIP_FILE" -d "$DIST_DIR"
fi

if [ ! -x "$GRADLE_BIN" ]; then
  echo "Gradle executable not found at $GRADLE_BIN" >&2
  find "$DIST_DIR" -maxdepth 3 -type f -name gradle -print >&2 || true
  exit 1
fi

exec "$GRADLE_BIN" "$@"
